#!/bin/sh
set -eu

ROOT=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)

if [ -n "${KONS_LIBDIR:-}" ]; then
  LIBDIR=$KONS_LIBDIR
  VENDORDIR=${KONS_VENDORDIR:-}
elif [ -d "$ROOT/src/kons" ]; then
  LIBDIR=$ROOT/src
  VENDORDIR=$ROOT/vendor
elif [ -d "$ROOT/lib/kons/src/kons" ]; then
  LIBDIR=$ROOT/lib/kons/src
  VENDORDIR=$ROOT/lib/kons/vendor
elif [ -d "$ROOT/share/kons/src/kons" ]; then
  LIBDIR=$ROOT/share/kons/src
  VENDORDIR=$ROOT/share/kons/vendor
else
  echo "kons: cannot find installed libraries; set KONS_LIBDIR" >&2
  exit 1
fi

scheme=${KONS_SCHEME:-${SCHEME:-capy}}
main=$LIBDIR/kons/main.scm
ARGS_SRCDIR=
CONDUIT_SRCDIR=
LOAD_PATH=

need_cmd() {
  command -v "$1" >/dev/null 2>&1
}

manager_command_available() {
  case "$1" in
    capy)
      need_cmd capy
      ;;
    gauche|gosh)
      need_cmd gosh
      ;;
    guile)
      need_cmd guile
      ;;
    chibi|chibi-scheme)
      need_cmd chibi-scheme
      ;;
    *)
      return 1
      ;;
  esac
}

select_doctor_manager_scheme() {
  if manager_command_available "$scheme"; then
    printf '%s\n' "$scheme"
    return 0
  fi
  if need_cmd capy; then
    printf '%s\n' capy
    return 0
  fi
  if need_cmd gosh; then
    printf '%s\n' gauche
    return 0
  fi
  if need_cmd guile; then
    printf '%s\n' guile
    return 0
  fi
  if need_cmd chibi-scheme; then
    printf '%s\n' chibi
    return 0
  fi
  return 1
}

global_option_takes_value() {
  case "$1" in
    --manifest|--path|--workspace-root|--scheme|--features|--target|--profile|--compile-mode|--hook-scheme|--log-level|--message-format|--jobs|-j)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

is_doctor_command() {
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --)
        shift
        if [ "${1:-}" = doctor ]; then
          return 0
        fi
        return 1
        ;;
      doctor)
        return 0
        ;;
      --manifest=*|--path=*|--workspace-root=*|--scheme=*|--features=*|--target=*|--profile=*|--compile-mode=*|--hook-scheme=*|--log-level=*|--message-format=*|--jobs=*)
        shift
        ;;
      -*)
        if global_option_takes_value "$1"; then
          shift
          [ "$#" -gt 0 ] || return 1
          shift
        else
          shift
        fi
        ;;
      *)
        return 1
        ;;
    esac
  done
  return 1
}

if is_doctor_command "$@" && ! manager_command_available "$scheme"; then
  if scheme=$(select_doctor_manager_scheme); then
    :
  else
    echo "kons: cannot run doctor; install capy, gosh, guile, or chibi-scheme" >&2
    exit 1
  fi
fi

if [ -n "${VENDORDIR:-}" ] && [ -d "$VENDORDIR/scm-args/src" ]; then
  ARGS_SRCDIR=$VENDORDIR/scm-args/src
elif [ -n "${VENDORDIR:-}" ] && [ -d "$VENDORDIR" ]; then
  ARGS_SRCDIR=$VENDORDIR
fi
if [ -n "${VENDORDIR:-}" ] && [ -d "$VENDORDIR/conduit/src" ]; then
  CONDUIT_SRCDIR=$VENDORDIR/conduit/src
fi

add_load_path() {
  if [ -n "$1" ]; then
    if [ -n "$LOAD_PATH" ]; then
      LOAD_PATH=$LOAD_PATH,$1
    else
      LOAD_PATH=$1
    fi
  fi
}

add_load_path "$ARGS_SRCDIR"
add_load_path "$CONDUIT_SRCDIR"
add_load_path "$LIBDIR"

case "$scheme" in
  capy)
    exec capy -L "$LOAD_PATH" -s "$main" -- "$@"
    ;;
  gauche|gosh)
    if [ -n "$ARGS_SRCDIR" ]; then
      if [ -n "$CONDUIT_SRCDIR" ]; then
        exec gosh -r7 -I "$ARGS_SRCDIR" -I "$CONDUIT_SRCDIR" -I "$LIBDIR" "$main" "$@"
      else
        exec gosh -r7 -I "$ARGS_SRCDIR" -I "$LIBDIR" "$main" "$@"
      fi
    elif [ -n "$CONDUIT_SRCDIR" ]; then
      exec gosh -r7 -I "$CONDUIT_SRCDIR" -I "$LIBDIR" "$main" "$@"
    else
      exec gosh -r7 -I "$LIBDIR" "$main" "$@"
    fi
    ;;
  guile)
    GUILE_AUTO_COMPILE=${GUILE_AUTO_COMPILE:-0}
    export GUILE_AUTO_COMPILE
    if [ -n "$ARGS_SRCDIR" ]; then
      if [ -n "$CONDUIT_SRCDIR" ]; then
        exec guile --r7rs -L "$ARGS_SRCDIR" -L "$CONDUIT_SRCDIR" -L "$LIBDIR" "$main" "$@"
      else
        exec guile --r7rs -L "$ARGS_SRCDIR" -L "$LIBDIR" "$main" "$@"
      fi
    elif [ -n "$CONDUIT_SRCDIR" ]; then
      exec guile --r7rs -L "$CONDUIT_SRCDIR" -L "$LIBDIR" "$main" "$@"
    else
      exec guile --r7rs -L "$LIBDIR" "$main" "$@"
    fi
    ;;
  chibi|chibi-scheme)
    if [ -n "$ARGS_SRCDIR" ]; then
      if [ -n "$CONDUIT_SRCDIR" ]; then
        exec chibi-scheme -I "$ARGS_SRCDIR" -I "$CONDUIT_SRCDIR" -I "$LIBDIR" "$main" "$@"
      else
        exec chibi-scheme -I "$ARGS_SRCDIR" -I "$LIBDIR" "$main" "$@"
      fi
    elif [ -n "$CONDUIT_SRCDIR" ]; then
      exec chibi-scheme -I "$CONDUIT_SRCDIR" -I "$LIBDIR" "$main" "$@"
    else
      exec chibi-scheme -I "$LIBDIR" "$main" "$@"
    fi
    ;;
  *)
    echo "kons: unsupported manager scheme: $scheme" >&2
    exit 1
    ;;
esac

# Copy to .env and fill in values before running docker compose up.
# See DEPLOY.md for the full deployment walkthrough.

# Public URL users and OAuth providers should use.
KONS_REGISTRY_BASE_URL=https://packages.example.org

# Strong random secret for sessions and email code hashing.
KONS_SESSION_SECRET=replace-with-openssl-rand-hex-32

# Admin accounts receive owner/admin powers on matching email.
KONS_ADMIN_EMAILS=you@gmail.com

# Email registration
KONS_EMAIL_REGISTRATION=1
# Allow any email address to register. Leave off to restrict to KONS_EMAIL_ALLOWLIST.
KONS_EMAIL_OPEN_REGISTRATION=1
# Optional allowlist when open registration is off:
# KONS_EMAIL_ALLOWLIST=you@gmail.com,@example.org
KONS_EMAIL_CODE_TTL_MINUTES=15
# Dev only: return codes in API responses when SMTP is not configured.
# KONS_EMAIL_SHOW_CODES=1

# Gmail SMTP (recommended for personal deployment)
# Create an App Password: Google Account -> Security -> 2-Step Verification -> App passwords
KONS_SMTP_HOST=smtp.gmail.com
KONS_SMTP_PORT=587
KONS_SMTP_USER=you@gmail.com
KONS_SMTP_PASS=your-16-char-app-password
KONS_SMTP_FROM=you@gmail.com

# Optional OAuth providers
# KONS_AUTH_GITHUB_CLIENT_ID=
# KONS_AUTH_GITHUB_CLIENT_SECRET=
# KONS_AUTH_GOOGLE_CLIENT_ID=
# KONS_AUTH_GOOGLE_CLIENT_SECRET=

# Optional S3-compatible archive storage
# KONS_STORAGE=s3
# KONS_S3_ENDPOINT=https://s3.example.org
# KONS_S3_REGION=us-east-1
# KONS_S3_BUCKET=kons
# KONS_S3_ACCESS_KEY_ID=
# KONS_S3_SECRET_ACCESS_KEY=
# KONS_S3_PUBLIC_BASE_URL=https://cdn.example.org/kons

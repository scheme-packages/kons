{
  "name": "kons-registry",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Self-hostable (kons) package registry",
  "scripts": {
    "start": "node server.js",
    "dev": "KONS_EMAIL_REGISTRATION=1 KONS_EMAIL_SHOW_CODES=1 KONS_EMAIL_OPEN_REGISTRATION=1 node server.js",
    "test": "node --test --test-concurrency=1 test/*.test.js",
    "check": "for file in server.js src/*.js public/shared.js public/app.js public/account.js public/route-views.js; do node --check \"$file\" || exit 1; done"
  },
  "engines": {
    "node": ">=26"
  },
  "dependencies": {
    "nodemailer": "^9.0.1"
  }
}
